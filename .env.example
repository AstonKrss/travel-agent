# LLM Configuration
LLM_PROVIDER=openai
LLM_TEMPERATURE=0.7

# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_REASONING_MODEL=gpt-4o

# Volcano Engine (alternative)
VOLCANO_API_KEY=
VOLCANO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCANO_MODEL=ep-m-20260326112043-hrs4j
VOLCANO_REASONING_MODEL=ep-m-20260326112043-hrs4j

# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGIN=*

# Mock mode (set false for real API calls)
USE_MOCK=true
