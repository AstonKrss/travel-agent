# ============================================
# Enterprise Travel Agent - Environment Configuration
# ============================================

# ============================================
# LLM Configuration (for real AI decision making)
# ============================================

# LLM Provider: openai / volcano (Volcano Engine/ByteDance)
# LLM_PROVIDER=volcano
# LLM_TEMPERATURE=0.7

# OpenAI Configuration
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Volcano Engine (ByteDance) Configuration (Doubao/Qwen)
# VOLCANO_API_KEY=your-volcano-api-key
# VOLCANO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# VOLCANO_MODEL=qwen3-72b-instruct
# (Use your custom model endpoint ID from Volcano Engine console)

# ============================================
# Speech Recognition ASR
# ============================================

# Alibaba Cloud ASR (Dashscope)
# DASHSCOPE_API_KEY=your-dashscope-api-key

# iFlytek ASR (Speech Recognition)
# IFYTEK_APPID=your-iflytek-appid
# IFYTEK_API_KEY=your-iflytek-api-key
# IFYTEK_API_SECRET=your-iflytek-api-secret

# TMC API Configuration (real enterprise travel service)
# TMC_API_BASE_URL=https://api.tmc-provider.com
# TMC_API_KEY=your-tmc-api-key
# TMC_COMPANY_ACCOUNT_ID=your-company-account-id

# OA/Finance System API
# OA_API_BASE_URL=https://oa.your-company.com
# OA_API_KEY=your-oa-api-key

# CORS Allow Origin (for production)
# ALLOWED_ORIGIN=https://your-frontend-domain.com
